<?xml version="1.0" encoding="UTF-8" ?>
<!--
    PHPUnit configuration for quizaccess_proview.

    Run from the Moodle root:
        vendor/bin/phpunit -testsuite quizaccess_proview

    Or via moodle-plugin-ci in CI (which handles Moodle bootstrap automatically).

    Coverage: use pcov or xdebug.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="lib/phpunit/phpunit_configuration.xsd">

    <testsuites>
        <testsuite name="quizaccess_proview">
            <directory suffix="_test.php">tests</directory>
        </testsuite>
    </testsuites>

    <coverage>
        <include>
            <directory suffix=".php">.</directory>
        </include>
        <exclude>
            <directory>tests</directory>
            <directory>vendor</directory>
        </exclude>
    </coverage>

</phpunit>
