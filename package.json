{
  "name": "quizaccess-proview",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "*.php": [
      "vendor/bin/parallel-lint --no-colors",
      "vendor/bin/phpcs --standard=moodle --no-cache",
      "bash -c 'vendor/bin/phpmd . text phpmd.xml --suffixes php || true'",
      "bash -c 'if [ -x ci/vendor/bin/moodle-phpdoc-checker ]; then ci/vendor/bin/moodle-phpdoc-checker --max-warnings 0; fi'"
    ]
  }
}
