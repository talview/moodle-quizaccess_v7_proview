{
  "name": "talview/quizaccess-proview",
  "description": "Unified Talview Proview proctoring quiz access plugin for Moodle",
  "license": "GPL-3.0-or-later",
  "type": "moodle-plugin",
  "authors": [
    {
      "name": "Talview Inc.",
      "homepage": "https://www.talview.com"
    }
  ],
  "require": {},
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.9",
    "moodle/moodle-cs": "^3.4",
    "phpstan/phpstan": "^1.12",
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "php-parallel-lint/php-console-highlighter": "^1.0"
  },
  "scripts": {
    "lint": "parallel-lint --exclude vendor .",
    "cs": "phpcs --standard=moodle --extensions=php .",
    "cs-fix": "phpcbf --standard=moodle --extensions=php .",
    "analyse": "phpstan analyse --memory-limit=512M",
    "check": [
      "@lint",
      "@cs",
      "@analyse"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
