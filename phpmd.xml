<?xml version="1.0"?>
<ruleset name="PHPMD rules for Moodle"
        xmlns="http://pmd.sf.net/ruleset/1.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
        xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>
        Moodle PHPMD ruleset — mirrors the config used by moodle-plugin-ci.
    </description>

    <rule ref="rulesets/codesize.xml">
        <!-- Test classes naturally have many test methods. -->
        <exclude name="TooManyPublicMethods"/>
    </rule>
    <rule ref="rulesets/unusedcode.xml">
        <!-- Interface stub implementations require all parameters by contract. -->
        <exclude name="UnusedFormalParameter"/>
    </rule>
    <rule ref="rulesets/naming.xml">
        <!-- Moodle uses short var names like $DB, $rs, $cm — exclude ShortVariable -->
        <exclude name="ShortVariable"/>
    </rule>
    <rule ref="rulesets/design.xml"/>
    <rule ref="rulesets/cleancode.xml/BooleanArgumentFlag"/>

</ruleset>
