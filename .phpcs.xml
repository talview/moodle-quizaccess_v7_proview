<?xml version="1.0"?>
<ruleset name="quizaccess_proview">
    <description>Moodle coding standard for quizaccess_proview</description>

    <rule ref="moodle"/>

    <!-- Source files -->
    <file>.</file>

    <!-- Exclusions -->
    <exclude-pattern type="relative">^vendor/</exclude-pattern>
    <exclude-pattern type="relative">^node_modules/</exclude-pattern>
    <exclude-pattern type="relative">^amd/build/</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>
</ruleset>
